# ===== CAS-Zugang =====
# Seite mit dem Login-Formular (wo du Nutzername/Passwort eingibst)
CAS_LOGIN_URL=https://campusoffice.deine-hochschule.de/
# Seite, auf der deine Noten stehen (URL nach dem Login kopieren)
CAS_GRADES_URL=https://campusoffice.deine-hochschule.de/views/studentmanagement/contractView.asp
CAS_USERNAME=dein_login
CAS_PASSWORD=dein_passwort

# Namen der Formularfelder im Login-Formular.
# Im Browser: Rechtsklick auf das Feld -> "Untersuchen" -> Attribut name="..." ablesen.
# Bei CampusOffice/CampusNet sind das oft u (Benutzer) und p (Passwort).
CAS_FIELD_USER=u
CAS_FIELD_PASS=p

# CSS-Selektor des Noten-Bereichs. Leer lassen = ganze Seite vergleichen.
# Bei CampusOffice ist die Notentabelle z.B. table.hierarchy
CAS_GRADES_SELECTOR=table.hierarchy

# ===== E-Mail-Benachrichtigung (GMX als Beispiel) =====
SMTP_HOST=mail.gmx.net
SMTP_PORT=587
SMTP_USER=deine@mail.de
SMTP_PASSWORD=dein_mailpasswort
MAIL_TO=deine@mail.de
